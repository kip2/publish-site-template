# Docker Compose 用の環境変数。
# このファイルを `.env` にコピーして編集してください（.env は .gitignore 済み）。
#
#   cp .env.example .env
#   $EDITOR .env


# ── 必須 ──────────────────────────────────────────────────────

# Vault の publish/ フォルダの絶対パス（ホスト側）
# コンテナ内では /vault-publish として readonly マウントされる
VAULT_PUBLISH_DIR=/home/User/Documents/main_vault/publish


# ── 任意 ──────────────────────────────────────────────────────

# サイト基本設定（未設定時は .publish.config の値、それも無ければデフォルト）
# QUARTZ_BASE_URL=localhost:8080
# QUARTZ_PAGE_TITLE=My Notes

# コンテナを実行する UID/GID。
# Linux ホストで生成ファイルが root 所有になるのを避けたいときに設定。
# 自分の UID/GID は `id -u` / `id -g` で確認。Mac/Windows では未設定で OK。
# USER_ID=1000
# GROUP_ID=1000
