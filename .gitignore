# Node
node_modules/
package-lock.json.backup
npm-debug.log*

# Quartz framework source (bootstrap.sh で取得、リポジトリには含めない)
quartz/

# Quartz build outputs
public/
.quartz-cache/

# Quartz upstream または overrides/ から bootstrap.sh が再生成するファイル
# - quartz.config.ts / quartz.layout.ts は overrides/ をコピーして作成
# - globals.d.ts / index.d.ts / tsconfig.json は Quartz upstream から取得
# - .prettierrc / .prettierignore も Quartz upstream 由来
/quartz.config.ts
/quartz.layout.ts
/globals.d.ts
/index.d.ts
/tsconfig.json
/.prettierrc
/.prettierignore

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Local environment
.env
.env.local

# 個別環境の publish-site 設定（マシン依存なので追跡しない）
.publish.config

# Bootstrap 中の一時ファイル
*.tmp
